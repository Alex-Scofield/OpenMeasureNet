{
  "title": "All Nodes",
  "uid": "all-nodes",
  "editable": true,
  "tags": ["nodes", "map"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "geomap",
      "title": "Nodes Locations",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "postgres_main"
      },
      "targets": [
        {
          "rawSql": "SELECT DISTINCT ON (node_id)\n  node_id,\n  node_id || '' AS title,\n  ST_X(location) AS longitude,\n  ST_Y(location) AS latitude,\n  value,\n  time\nFROM observations\nORDER BY node_id, time DESC",
          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "postgres",
            "uid": "postgres_main"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "opacity": 0.8,
            "borderWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "basemap": {
          "name": "OpenStreetMap",
          "type": "osm-standard"
        },
        "controls": {
          "showZoom": true,
          "mouseWheelZoom": true
        },
        "tooltip": {
          "mode": "multi"
        },
        "view": {
          "id": "fit",
          "lat": 0,
          "lng": 0,
          "zoom": 2
        }
      }
    },
    {
      "id": 2,
      "type": "table",
      "title": "Nodes Data",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "postgres_main"
      },
      "targets": [
        {
          "rawSql": "SELECT DISTINCT ON (node_id)\n  node_id,\n  value,\n  time,\n  ST_X(location) AS longitude,\n  ST_Y(location) AS latitude\nFROM observations\nWHERE quantity = $quantity\nORDER BY node_id, time DESC",
          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "postgres",
            "uid": "postgres_main"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {}
      },
      "options": {}
    }
  ],
  "templating": {
    "list": [
      {
        "name": "quantity",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "postgres_main"
        },
        "query": "SELECT id AS __value, name AS __text FROM quantities ORDER BY id",
        "refresh": 1,
        "sort": 1,
        "label": "Quantity",
        "current": {
          "text": "Temperature",
          "value": "1"
        },
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  }
}
